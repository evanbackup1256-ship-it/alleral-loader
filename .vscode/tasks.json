{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Alleral: sync repo",
      "type": "shell",
      "command": "pwsh -NoProfile -File maint/sync_repo.ps1",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Alleral: verify",
      "type": "shell",
      "command": "pwsh -NoProfile -Command \"./maint/verify_versions.ps1; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; ./maint/verify_ui_compat.ps1\"",
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Alleral: bump release",
      "type": "shell",
      "command": "pwsh -NoProfile -File maint/bump_release.ps1",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    }
  ]
}